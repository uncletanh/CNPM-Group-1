# Database Connection String (Lấy từ Supabase hoặc Neon.tech)
DATABASE_URL=postgresql://postgres:password@host:5432/dbname

# JWT Secret Key (Đổi chuỗi này trên server thật)
SECRET_KEY=your-super-secret-key-change-me-in-production

# Thuật toán JWT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Bắt buộc phải cài Ollama (https://ollama.com) và chạy `ollama pull qwen2.5:3b`
# truoc khi /api/v1/chat hoat dong, neu khong se bi loi 503 "Khong the ket noi Ollama".
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT_SECONDS=120
REDIS_URL=redis://localhost:6379/0
HUMAN_HANDOFF_TIMEOUT_SECONDS=60
RAG_MAX_DISTANCE=1.2
CHAT_HISTORY_LIMIT=10
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FRONTEND_URL=http://localhost:5173
RATE_LIMIT_PER_MINUTE=30
LOG_LEVEL=INFO
