# Database Connection String (Lấy từ Supabase hoặc Neon.tech)
DATABASE_URL=postgresql://postgres:password@host:5432/dbname

# JWT Secret Key (Đổi chuỗi này trên server thật)
SECRET_KEY=your-super-secret-key-change-me-in-production

# Thuật toán JWT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Chọn ollama, groq, gemini hoặc auto. Chế độ auto thử theo LLM_FALLBACK_ORDER.
LLM_PROVIDER=auto
LLM_FALLBACK_ORDER=ollama,groq,gemini
LLM_FALLBACK_PROVIDERS=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT_SECONDS=120
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_SECONDS=60
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=60
EMBEDDING_PROVIDER=auto
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSION=768
GEMINI_EMBEDDING_TIMEOUT_SECONDS=30
REDIS_URL=redis://localhost:6379/0
HUMAN_HANDOFF_TIMEOUT_SECONDS=60
# Để trống để dùng mặc định theo provider: Gemini 0.9, local 1.3.
RAG_MAX_DISTANCE=
BM25_MIN_SCORE=5.5
HYBRID_SEMANTIC_WEIGHT=0.7
HYBRID_RRF_K=60
CHAT_HISTORY_LIMIT=10
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FRONTEND_URL=http://localhost:5173
RATE_LIMIT_PER_MINUTE=30
LOG_LEVEL=INFO
